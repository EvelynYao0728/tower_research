# =============================================================================
# QuantaAlpha — Claude（Anthropic Messages API，OpenAI SDK 兼容层）
# 网关 anthropic 接口: POST {ANTHROPIC_BASE_URL}/messages  → 配置 base 须含 /v1
# =============================================================================

DATA_RESULTS_DIR="./data/results"

# --- API 根地址（须以 /v1 结尾，客户端请求 /v1/chat/completions 或网关转 /v1/messages）---
ANTHROPIC_BASE_URL=https://main-new.codesuc.top

# --- 令牌 ---
ANTHROPIC_API_KEY=sk-dQqt9odVkW6WwiPsMtZ6SYLA01WpeTkcBK3RzrQ6GRjh9qnK
# --- 模型名（与网关控制台一致）---
CHAT_MODEL=claude-sonnet-4-6
REASONING_MODEL=claude-sonnet-4-6

USE_LOCAL=True
MAX_RETRY=5
RETRY_WAIT_SECONDS=5
FACTOR_MINING_TIMEOUT=999999
CHAT_MAX_TOKENS=8192
CHAT_MAX_TOKENS_CAP=16384
CHAT_TEMPERATURE=0.7
CHAT_STREAM=false

# 全量 eval 默认（0=全部交易日）；Debugging 天数由 FACTOR_CoSTEER_DEBUG_PANEL_MAX_DAYS 单独控制
QUANTALPHA_TEMPLATE_PANEL_MAX_DAYS=0
QUANTALPHA_FACTOR_EVAL_WORKERS=4
FACTOR_CoSTEER_MAX_LOOP=5
# CoSTEER Debugging 进度条阶段：仅最近 N 天验证代码
FACTOR_CoSTEER_DEBUG_PANEL_MAX_DAYS=3
# Debugging 通过后自动全量生成因子 + 写入 per-feature 日分片，再回测
FACTOR_CoSTEER_PROMOTE_FULL_PANEL_AFTER_DEBUG=true
FACTOR_CoSTEER_INPROCESS_FACTOR_EVAL=true
FACTOR_CoSTEER_SKIP_WORKSPACE_DATA_SYMLINK=true
MULTI_PROC_N=1
